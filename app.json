{
  "name": "WZML-X Leech Bot",
  "description": "Telegram leech bot supporting direct links, torrents, yt-dlp, JDownloader and Usenet",
  "repository": "https://github.com/your-repo/WZML-X",
  "keywords": ["telegram", "bot", "leech", "python"],
  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-apt"
    },
    {
      "url": "heroku/python"
    }
  ],
  "env": {
    "BOT_TOKEN": {
      "description": "Telegram Bot Token from @BotFather",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram User ID",
      "required": true
    },
    "TELEGRAM_API": {
      "description": "API ID from https://my.telegram.org",
      "required": true
    },
    "TELEGRAM_HASH": {
      "description": "API Hash from https://my.telegram.org",
      "required": true
    },
    "DATABASE_URL": {
      "description": "MongoDB connection string (use MongoDB Atlas free tier)",
      "required": true
    },
    "LEECH_DUMP_CHAT": {
      "description": "Telegram chat/channel ID to send leeched files",
      "required": false
    },
    "DOWNLOAD_DIR": {
      "description": "Download directory path",
      "value": "/tmp/downloads/"
    },
    "DISABLE_TORRENTS": {
      "description": "Set True to disable qBittorrent (saves memory)",
      "value": "True"
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "standard-2x"
    }
  }
}
